{
  "name": "DarkAuth",
  "version": "1.0.0",
  "license": "AGPL-3.0",
  "description": "Zero-knowledge authentication system with OIDC compatibility",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm dev:ui\" \"pnpm dev:admin\" \"pnpm dev:api\"",
    "dev:api": "pnpm --filter @DarkAuth/api dev",
    "dev:ui": "pnpm --filter @DarkAuth/user-ui dev",
    "dev:admin": "pnpm --filter @DarkAuth/admin-ui dev",
    "dev:brochureware": "pnpm --filter @DarkAuth/brochureware dev",
    "dev:docs": "pnpm --filter @DarkAuth/docs dev",
    "build": "node scripts/build-workspaces.mjs",
    "build:ui": "pnpm --filter @DarkAuth/user-ui build",
    "build:admin": "pnpm --filter @DarkAuth/admin-ui build",
    "build:api": "pnpm --filter @DarkAuth/api build",
    "start": "pnpm --filter @DarkAuth/api start",
    "test:report": "pnpm --filter @DarkAuth/test-suite test:report",
    "test:install": "pnpm --filter @DarkAuth/test-suite install:playwright",
    "test:screenshots": "pnpm --filter @DarkAuth/test-suite test:screenshots",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "pnpm -r --if-present format",
    "lint": "pnpm -r --if-present lint",
    "check": "pnpm -r --if-present check",
    "check:fix": "pnpm -r --if-present check:fix",
    "tidy": "pnpm -r --if-present tidy",
    "test": "pnpm -r --if-present test",
    "db:push": "pnpm --filter @DarkAuth/api db:push",
    "db:generate": "pnpm --filter @DarkAuth/api db:generate",
    "db:migrate": "pnpm --filter @DarkAuth/api db:migrate",
    "db:wipe": "pnpm --filter @DarkAuth/api db:wipe",
    "install:script": "pnpm --filter @DarkAuth/api install:script",
    "demodb:wipe": "pnpm --filter @DarkAuth/demo-app demodb:wipe",
    "demodb:push": "pnpm --filter @DarkAuth/demo-app demodb:push",
    "demo:dev": "concurrently \"pnpm --filter @DarkAuth/demo-app dev\" \"pnpm --filter @DarkAuth/demo-app server\"",
    "clean": "rm -rf packages/api/data packages/demo-app/data ./config.yaml ../config.yaml ../../config.yaml ../../../config.yaml packages/api/config.yaml && echo \"Clean complete: install state removed.\""
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "upload-to-bunny": "^2.1.1"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "semantic-release": "^25.0.5"
  }
}
