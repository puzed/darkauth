{
	"name": "@DarkAuth/api",
	"version": "0.0.0",
	"license": "AGPL-3.0",
	"description": "DarkAuth API server with OPAQUE authentication and OIDC compatibility",
	"type": "module",
	"main": "src/main.ts",
	"scripts": {
		"dev": "node --env-file-if-exists=../../.env --watch src/main.ts",
		"build": "tsc --noEmit",
		"start": "node --env-file-if-exists=../../.env src/main.ts",
		"test": "node --env-file-if-exists=../../.env --test src/**/*.test.ts",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node --env-file-if-exists=../../.env src/db/migrate.ts",
		"db:wipe": "node --env-file-if-exists=../../.env scripts/wipe.ts",
		"install:script": "node --env-file-if-exists=../../.env scripts/install.ts",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"tidy": "biome check --write . && biome lint --write ."
	},
	"dependencies": {
		"@cloudflare/voprf-ts": "1.0.0",
		"@electric-sql/pglite": "^0.5.2",
		"@peculiar/webcrypto": "^1.7.1",
		"@simplewebauthn/server": "^13.3.1",
		"argon2": "^0.44.0",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"jose": "^6.2.3",
		"nodemailer": "^8.0.11",
		"opaque-ts": "workspace:*",
		"pg": "^8.21.0",
		"pino": "^10.3.1",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^25.9.3",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
